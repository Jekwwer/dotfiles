root = true

# NOTE: 'max_line_length' is a style guideline reference; not enforced by EditorConfig itself.

[*]
charset = utf-8
end_of_line = lf
indent_size = 2
indent_style = space
insert_final_newline = true
max_line_length = 88
trim_trailing_whitespace = true

[*.md]
max_line_length = 120
trim_trailing_whitespace = false

[*.json]
max_line_length = 88

[*.sh]
indent_size = 4

[*.{txt,log}]
trim_trailing_whitespace = false

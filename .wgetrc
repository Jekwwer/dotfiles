# .wgetrc: Configures the behavior of the wget command-line tool.

# Retry failed downloads up to 3 times
tries = 3

# Network timeouts
connect_timeout = 15
read_timeout = 20
dns_timeout = 10

# Resume interrupted downloads
continue = on

# SSL/TLS settings using the system's CA certificates
ca_directory = /etc/ssl/certs

# (Optional) Enable recursive downloads if needed; comment out for single-file downloads
# recursive = on
# level = 5

# (Optional) Limit download speed (uncomment to enable, e.g., 500 KB/s)
# limit_rate = 500k

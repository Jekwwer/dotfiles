# === File Classification ===

# All files: auto-detect text and normalize line endings
* text=auto

# --- Text: web / JS ecosystem ---
*.js        text eol=lf
*.cjs       text eol=lf
*.mjs       text eol=lf
*.ts        text eol=lf
*.tsx       text eol=lf
*.jsx       text eol=lf
*.html      text eol=lf
*.css       text eol=lf
*.scss      text eol=lf
*.less      text eol=lf

# --- Text: languages ---
*.py        text eol=lf
*.go        text eol=lf
*.rs        text eol=lf
*.rb        text eol=lf
*.java      text eol=lf
*.kt        text eol=lf
*.c         text eol=lf
*.cpp       text eol=lf
*.swift     text eol=lf

# --- Text: shell / build ---
*.sh        text eol=lf
Makefile    text eol=lf
Dockerfile  text eol=lf

# --- Text: data / config ---
*.json      text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.toml      text eol=lf
*.xml       text eol=lf
*.lock      text eol=lf

# --- Text: docs ---
*.md        text eol=lf
*.adoc      text eol=lf
*.rst       text eol=lf
*.txt       text eol=lf
*.csv       text eol=lf
*.tsv       text eol=lf

# --- Text: SVG (HTML-based markup, hand-editable) ---
*.svg       text eol=lf diff=html

# --- Binary: images ---
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.bmp       binary
*.tiff      binary
*.webp      binary
*.heic      binary
*.avif      binary
*.ico       binary
*.pdf       binary

# --- Binary: audio / video ---
*.mp3       binary
*.mp4       binary
*.mov       binary
*.wav       binary
*.ogg       binary

# --- Binary: fonts ---
*.ttf       binary
*.otf       binary
*.woff      binary
*.woff2     binary
*.eot       binary

# --- Binary: archives ---
*.zip       binary
*.gz        binary
*.bz2       binary
*.xz        binary
*.7z        binary
*.rar       binary
*.iso       binary

# --- Binary: executables / compiled ---
*.exe       binary
*.dll       binary
*.so        binary
*.dylib     binary
*.pyc       binary
*.class     binary
*.jar       binary

# --- Binary: packages ---
*.deb       binary
*.rpm       binary
*.dmg       binary

# --- Binary: databases ---
*.sqlite    binary
*.db        binary

# === Diff Behavior ===

# Custom diff drivers (markup-aware hunk headers)
*.json      diff=json
*.xml       diff=html

# Suppress diffs (too noisy or not useful)
*.log               -diff
*.lock              -diff
package-lock.json   -diff

# === Metadata ===

# --- GitHub linguist: generated outputs ---
*.min.js            linguist-generated
*.map               linguist-generated
*.bundle.js         linguist-generated
*.chunk.js          linguist-generated
package-lock.json   linguist-generated
yarn.lock           linguist-generated
poetry.lock         linguist-generated
Cargo.lock          linguist-generated
dist/*              linguist-generated
build/*             linguist-generated
coverage/*          linguist-generated

# --- GitHub linguist: vendored dependencies ---
vendor/*            linguist-vendored

# --- Export ignore (excluded from `git archive`) ---
*.bak           export-ignore
*.tmp           export-ignore
*.swp           export-ignore
*.DS_Store      export-ignore
.idea/          export-ignore
.vscode/        export-ignore
node_modules/   export-ignore

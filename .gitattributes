# === Text File Settings ===
# Auto-detect text files and normalize line endings in the repository
* text=auto

# Force LF line endings for these file types on checkout
*.sh        text eol=lf
*.py        text eol=lf
*.js        text eol=lf
*.ts        text eol=lf
*.tsx       text eol=lf
*.css       text eol=lf
*.html      text eol=lf
*.java      text eol=lf
*.c         text eol=lf
*.cpp       text eol=lf
*.md        text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.json      text eol=lf
*.xml       text eol=lf
*.toml      text eol=lf

# === Binary File Settings ===
# Prevent line ending conversion and mark as non-mergeable
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.svg       binary
*.pdf       binary
*.ico       binary
*.ttf       binary
*.otf       binary
*.woff      binary
*.woff2     binary

# === File-Specific Diff Algorithms ===
# Use structured diff drivers for more readable output
*.json      diff=json
*.xml       diff=xml

# === Large Files ===
# Skip diffing for files where diffs are not useful
*.log       -diff
*.zip       binary
*.tar.gz    binary
*.iso       binary

# === Linguist Settings ===
# Exclude generated files from GitHub language statistics
*.min.js    linguist-generated
*.map       linguist-generated

# === Export Settings ===
# Exclude these from `git archive` exports
*.bak       export-ignore
*.tmp       export-ignore
*.swp       export-ignore
*.DS_Store  export-ignore
.idea/      export-ignore
.vscode/    export-ignore
node_modules/ export-ignore

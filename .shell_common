# === Environment Variables ===
export EDITOR='vim'
export VISUAL='vim'
export PAGER='less'
export LESS='FRX'
export PATH="$HOME/bin:$HOME/.local/bin:$PATH"

export LANG='en_US.UTF-8'
export LC_ALL='en_US.UTF-8'

# === Aliases ===
# --- ls ---
alias ll='ls -la'
alias la='ls -A'
alias l='ls -CF'

# --- safety ---
alias rm='rm -i'
alias mv='mv -i'
alias cp='cp -i'

# --- navigation ---
alias ..='cd ..'
alias ...='cd ../..'
alias ....='cd ../../..'

# --- git ---
alias gst='git status'
alias gca='git amend'
alias gci='git commit'
alias gf='git fetch'
alias gfi='git fixup'
alias gpl='git pull'
alias gps='git push'
alias gpf='git push --force-with-lease'
alias gco='git checkout'
alias gsw='git switch'
alias grs='git restore'
alias gd='git diff'
alias gds='git diff --staged'
alias gb='git branch'
alias gl='git log --oneline --graph'
alias gla='git log --all --oneline --graph'
alias glm='git log --pretty=format:"%C(auto)%h %C(bold blue)%an %C(auto)%d %s%n%b%C(reset)" --graph --decorate --abbrev-commit'
alias gri='git rebase -i'
alias gsv='git stash push'
alias gun='git reset HEAD~1'
alias gdel='git push origin --delete'

# OS-specific: colors and package manager
if [[ "$(uname)" == 'Darwin' ]]; then
    export CLICOLOR=1
    export LSCOLORS=GxFxCxDxBxegedabagaced
    alias update='brew update && brew upgrade && brew cleanup'
else
    alias ls='ls --color=auto'
    alias update='sudo apt update && sudo apt upgrade -y && sudo apt autoremove'
fi

# === Functions ===
hgrep() {
    history | grep "$@"
}

reload() {
    if [[ -n "$ZSH_VERSION" ]]; then
        source ~/.zshrc
    else
        source ~/.bashrc
    fi
    echo 'Shell configuration reloaded!'
}

gignore() {
    if [[ $# -eq 0 ]]; then
        echo 'Usage: gignore <pattern>...' >&2
        return 1
    fi
    local exclude
    exclude=$(git rev-parse --git-path info/exclude 2>/dev/null) || {
        echo 'gignore: not a git repo' >&2
        return 1
    }
    printf '%s\n' "$@" >> "$exclude"
    echo "Added to $exclude"
}

# === Git Prompt ===
git_branch() {
    local ref
    if ref=$(git symbolic-ref --short HEAD 2>/dev/null); then
        echo "$ref"
    elif ref=$(git rev-parse --short HEAD 2>/dev/null); then
        echo "($ref)"
    fi
}

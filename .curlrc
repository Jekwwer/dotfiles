--progress-bar

# https for schemeless URLs (e.g. `curl example.com`)
--proto-default https

--compressed

# follow redirects
--location
--max-redirs 10

# 5xx/408/429/network only — 4xx excluded by design, don't add --retry-all-errors
--retry 3

--connect-timeout 15
# override with --max-time 0 for large downloads
--max-time 120

# TLS 1.2 floor — portable across all curl backends
--tlsv1.2

# stricter cert/key check — OpenSSL backend only (LibreSSL/Schannel reject)
# --ciphers DEFAULT:@SECLEVEL=2

# exit non-zero on HTTP errors (4xx/5xx), still print body
--fail-with-body

# --include        # show response headers
# --verbose

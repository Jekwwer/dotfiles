--progress-bar
--location         # follow redirects

# retry up to 3 times on any error, including HTTP 5xx
--retry 3
--retry-all-errors

--connect-timeout 15
--max-time 120     # override with --max-time 0 for large downloads

# enforce 2048-bit keys and SHA-256+ signatures
--ciphers DEFAULT:@SECLEVEL=2

--fail-with-body   # exit non-zero on HTTP errors (4xx/5xx), still print body

# --include        # show response headers
# --verbose
